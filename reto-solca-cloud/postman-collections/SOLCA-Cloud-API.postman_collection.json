{
  "info": {
    "name": "SOLCA Cloud - API REST",
    "description": "Coleccion completa para probar todos los microservicios del Repositorio Clinico Regional SOLCA.\n\n## Flujo de prueba recomendado:\n0. Obtener token (Autenticacion → Login)\n1. Crear un paciente (Pacientes → POST Registrar)\n2. Editar paciente (Pacientes → PUT Editar)\n3. Registrar consulta (Consultas → POST Registrar)\n4. Registrar laboratorio (Laboratorio → POST Registrar)\n5. Editar laboratorio (Laboratorio → PUT Editar)\n6. Registrar imagen (Imagenologia → POST Registrar)\n7. Editar imagen (Imagenologia → PUT Editar)\n8. Consultar repositorio consolidado (Repositorio → GET Consultar)\n9. Verificar auditoria (Auditoria → GET Listar)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081/api", "type": "string" },
    { "key": "consultasUrl", "value": "http://localhost:8082/api", "type": "string" },
    { "key": "laboratorioUrl", "value": "http://localhost:8083/api", "type": "string" },
    { "key": "imagenologiaUrl", "value": "http://localhost:8084/api", "type": "string" },
    { "key": "repositorioUrl", "value": "http://localhost:8085/api", "type": "string" },
    { "key": "seguridadUrl", "value": "http://localhost:8086/api", "type": "string" },
    { "key": "auditoriaUrl", "value": "http://localhost:8087/api", "type": "string" },
    { "key": "pacienteId", "value": "PAC-00001", "type": "string" },
    { "key": "cedula", "value": "0102030405", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "labId", "value": "1", "type": "string" },
    { "key": "imgId", "value": "1", "type": "string" }
  ],
  "item": [
    {
      "name": "0. AUTENTICACION",
      "description": "Autenticacion JWT. Obtener token para usar en los demas endpoints.",
      "item": [
        {
          "name": "0.1 Login - Obtener Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.token) {",
                  "    pm.collectionVariables.set('token', jsonData.data.token);",
                  "    console.log('Token obtenido: ' + jsonData.data.token.substring(0, 30) + '...');",
                  "}",
                  "pm.test('Status 200 OK', () => pm.response.to.have.status(200));",
                  "pm.test('Response tiene status success', () => pm.expect(jsonData.status).to.eql('success'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"medico1\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{seguridadUrl}}/auth/login",
              "host": ["{{seguridadUrl}}"],
              "path": ["auth", "login"]
            },
            "description": "Usuarios disponibles: admin, medico1, medico2, lab1, lab2, imagen1, imagen2, auditor1. Todos con password: admin123"
          }
        },
        {
          "name": "0.2 Health - Seguridad",
          "request": {
            "method": "GET",
            "url": { "raw": "{{seguridadUrl}}/actuator/health" }
          }
        }
      ]
    },
